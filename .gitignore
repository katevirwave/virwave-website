# OS files
.DS_Store
Thumbs.db
Desktop.ini

# Editor files
.vscode/
.idea/
*.swp
*.swo
*~

# Claude Code local settings (project settings are committed)
.claude/settings.local.json

# Node (not used, but just in case)
node_modules/
npm-debug.log*

# Build outputs
dist/
build/

# Environment files
.env
.env.*

# Local dev
_local*/
*.patch

# Python
.venv/
__pycache__/
*.pyc

# Generated QR codes (images are build artifacts; manifest is tracked)
assets/qr/*.png
assets/qr/*.webp

# Debug artifacts (screenshots, puppeteer cache, etc.)
.debug/

# Supabase CLI transient state (migrations are tracked; .temp is not)
supabase/.temp/
supabase/.branches/
# Stub files for remote-only virwave_v3 migrations (sync scaffolding, not real SQL)
supabase/migrations/*_stub.sql
